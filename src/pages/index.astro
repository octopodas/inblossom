    aesthetic: 'Calm & Refined',
    colors: ['#E8DED1', '#C4785A', '#2C2C2C', '#FAF7F2', '#7A7A5E'],
    fonts: 'DM Serif Display + Outfit',
    badge: 'Light',
  },
