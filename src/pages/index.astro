---
const variants = [
  {
    id: 1,
    file: '/variant-1-botanical-noir.html',
    screenshot: '/screenshots/variant-1.webp',
    name: 'Botanical Noir',
    description: 'Dark editorial luxury with gold foil accents, botanical SVG line art, and glassmorphism service cards.',
    aesthetic: 'Luxurious & Intimate',
    colors: ['#0A0A0A', '#0D1F0D', '#C4A265', '#F5F0E8', '#8B9A6B'],
    fonts: 'Playfair Display + Cormorant Garamond + Jost',
    badge: 'Dark',
